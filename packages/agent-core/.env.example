# DeepSeek（Mastra 原生支持，推荐）
# 申请地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key

# 问财 MCP（可选，用于 investmentAgent / 板块选股 / 投委会）
# 申请：https://www.iwencai.com/skillhub
# IWENCAI_API_KEY=sk-...
# IWENCAI_BASE_URL=https://openapi.iwencai.com
# IWENCAI_MCP_SERVER_PATH=/absolute/path/to/iwencai-mcp/server.py

# 可选：切换模型（默认 deepseek-v4-flash，性价比高、支持 Tool）
# DEEPSEEK_MODEL=deepseek/deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek/deepseek-chat
# DEEPSEEK_MODEL=deepseek/deepseek-reasoner
# DEEPSEEK_MODEL=deepseek/deepseek-v4-pro
