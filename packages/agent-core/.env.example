# DeepSeek（Mastra 原生支持，推荐默认）
# 申请地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key

# AI 模型（provider/model-name）
AI_MODEL=deepseek/deepseek-v4-flash

# 可选：其他 AI 提供商 API Key
# DASHSCOPE_API_KEY=      # 通义千问
# MOONSHOT_API_KEY=       # Kimi
# ZHIPU_API_KEY=          # 智谱 GLM
# MINIMAX_API_KEY=        # MiniMax
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=

# HTTP 服务
PORT=4000
# 可选：设置后 Web 请求须带 Authorization: Bearer <token>
# AGENT_CORE_TOKEN=your-shared-secret

# 本地后台消息雷达（agent-core serve 启动后默认开启）
# MONITOR_BACKGROUND_ENABLED=1
# MONITOR_BACKGROUND_INTERVAL_MS=300000
# 自动加池：balanced（默认）| aggressive | notify_only
# MONITOR_AUTO_TRACK=balanced
# 次日晚几点清理前一日消息雷达数据（北京时间，默认 20）
# MONITOR_PURGE_HOUR=20

# 推荐：Turso 远程数据库
# LIBSQL_URL=libsql://your-db.turso.io
# LIBSQL_AUTH_TOKEN=

# 问财 MCP（可选，用于选股 / 投委会）
# IWENCAI_API_KEY=sk-...
# IWENCAI_BASE_URL=https://openapi.iwencai.com
# IWENCAI_MCP_SERVER_PATH=/absolute/path/to/iwencai-mcp/server.py

# 可选：切换模型（推荐使用 AI_MODEL；DEEPSEEK_MODEL 仍兼容）
# AI_MODEL=deepseek/deepseek-chat
# DEEPSEEK_MODEL=deepseek/deepseek-v4-flash
