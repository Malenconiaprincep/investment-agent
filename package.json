{
  "name": "investment-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A-share investment research agent powered by Mastra",
  "scripts": {
    "dev": "pnpm --filter @investment-agent/agent-core dev",
    "chat": "pnpm --filter @investment-agent/agent-core chat",
    "ingest": "pnpm --filter @investment-agent/agent-core ingest",
    "eval": "pnpm --filter @investment-agent/agent-core eval",
    "eval:workflow": "pnpm --filter @investment-agent/agent-core eval:workflow",
    "eval:screen": "pnpm --filter @investment-agent/agent-core eval:screen",
    "screen": "pnpm --filter @investment-agent/agent-core screen",
    "committee": "pnpm --filter @investment-agent/agent-core committee",
    "research": "pnpm --filter @investment-agent/agent-core research",
    "build": "pnpm -r build",
    "web:dev": "pnpm --filter @investment-agent/web dev",
    "web:build": "pnpm --filter @investment-agent/web build",
    "setup:iwencai": "pnpm --filter @investment-agent/agent-core setup:iwencai",
    "watchlist:snapshot": "pnpm --filter @investment-agent/agent-core watchlist:snapshot",
    "watchlist:weekly": "pnpm --filter @investment-agent/agent-core watchlist:weekly",
    "design:audit": "npx impeccable detect apps/web/app apps/web/components",
    "eval:all": "pnpm --filter @investment-agent/agent-core eval:all"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
