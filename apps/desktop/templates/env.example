# 投研助手桌面版配置（首次启动会自动复制到用户目录）
# macOS: ~/Library/Application Support/投研助手/.env
# Windows: %APPDATA%/投研助手/.env
#
# 也可在应用内打开「设置 → API 配置」填写，保存后重启应用生效。

# 必填：AI 模型与对应提供商 API Key（至少配置当前模型所需 Key）
# 模型格式：provider/model-name，见 https://mastra.ai/models
AI_MODEL=deepseek/deepseek-v4-flash

# DeepSeek（默认模型）
# 申请地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key

# 可选：其他 AI 提供商（切换 AI_MODEL 时使用）
# DASHSCOPE_API_KEY=
# MOONSHOT_API_KEY=
# ZHIPU_API_KEY=
# MINIMAX_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=

# 问财 MCP（智能选股 / 投委会，必填才能使用板块选股）
# 申请后填入 sk-... 格式的 Key
IWENCAI_API_KEY=
IWENCAI_BASE_URL=https://openapi.iwencai.com

# 可选：远程 Turso 数据库
# LIBSQL_URL=libsql://your-db.turso.io
# LIBSQL_AUTH_TOKEN=

# 可选：agent-core 鉴权（一般桌面版可留空）
# AGENT_CORE_TOKEN=

# 可选：飞书推送（App 与 Webhook 二选一，App 优先）
# 企业自建应用：open.feishu.cn → 创建应用 → 权限 im:message:send_as_bot + im:chat:readonly
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# FEISHU_CHAT_ID=oc_xxxxxxxx
#
# 或群自定义机器人 Webhook：
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# FEISHU_WEBHOOK_SECRET=
# FEISHU_NOTIFY_ENABLED=0
# FEISHU_NOTIFY_STOCK_INTRADAY=0
# FEISHU_NOTIFY_MONITOR=0
# FEISHU_NOTIFY_ETF_MONITOR=1
# STOCK_INTRADAY_MONITOR_INTERVAL_MINUTES=15
# MONITOR_BACKGROUND_INTERVAL_MS=300000
