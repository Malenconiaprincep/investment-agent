# 投研助手桌面版配置（首次启动会自动复制到用户目录）
# macOS: ~/Library/Application Support/投研助手/.env
# Windows: %APPDATA%/投研助手/.env

# 必填：DeepSeek API Key
# 申请地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key

# 可选：问财 MCP（智能选股 / 投委会）
# IWENCAI_API_KEY=sk-...
# IWENCAI_BASE_URL=https://openapi.iwencai.com

# 可选：远程 Turso 数据库
# LIBSQL_URL=libsql://your-db.turso.io
# LIBSQL_AUTH_TOKEN=

# 可选：agent-core 鉴权（一般桌面版可留空）
# AGENT_CORE_TOKEN=
