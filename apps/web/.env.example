# 本地开发：复制为 .env.local
# cp apps/web/.env.example apps/web/.env.local

# agent-core HTTP 服务（本地先运行 pnpm agent:serve）
AGENT_CORE_URL=http://127.0.0.1:4000

# 可选：与 packages/agent-core/.env 中的 AGENT_CORE_TOKEN 保持一致
AGENT_CORE_TOKEN=

# 可选：仅手动调试 Monitor CLI 时开启；默认 Web 会走 agent-core HTTP
# AGENT_CORE_MONITOR_LOCAL_EXEC=1

# 部署到 Vercel 时改为远程 agent-core 地址，例如：
# AGENT_CORE_URL=https://your-agent-core.example.com

# Supabase（Market 用户表，见 docs/supabase-market-users.md）
# SUPABASE_URL=https://jixkzyrresmceaekjian.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_PROJECT_REF=jixkzyrresmceaekjian

# 会话签名密钥（生产环境必填，openssl rand -base64 32）
# AUTH_SESSION_SECRET=
