# Vercel 环境变量（在 Dashboard → Settings → Environment Variables 配置）

# 必填：DeepSeek API Key（生成研报）
DEEPSEEK_API_KEY=

# 可选：问财 API（智能选股 / 深度分析需要；Vercel 上需 Python MCP，可能不可用）
# IWENCAI_API_KEY=
# IWENCAI_BASE_URL=https://openapi.iwencai.com

# 推荐：Turso 远程数据库（toC 持久化研报/选股记录）
# 创建：https://turso.tech → 拿到 libsql:// URL 和 auth token
# LIBSQL_URL=libsql://your-db.turso.io
# LIBSQL_AUTH_TOKEN=

# 可选：笔记向量库 / Agent 记忆（不配置则 RAG 笔记检索为空）
# LIBSQL_NOTES_URL=
# LIBSQL_MEMORY_URL=
