{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @investment-agent/web build",
  "framework": "nextjs",
  "regions": ["hkg1"],
  "crons": [
    { "path": "/api/cron/daily-snapshot", "schedule": "30 7 * * 1-5" },
    { "path": "/api/cron/monitor-poll", "schedule": "*/15 1-3,5-7 * * 1-5" },
    { "path": "/api/cron/etf-tail-pick", "schedule": "0 6 * * 1-5" },
    { "path": "/api/cron/weekly-review", "schedule": "0 0 * * 1" },
    { "path": "/api/cron/diamond-scan", "schedule": "35 7 * * 1-5" },
    { "path": "/api/cron/etf-paper-auto", "schedule": "30 6 * * 1-5" },
    { "path": "/api/cron/paper-auto", "schedule": "5 7 * * 1-5" }
  ]
}
